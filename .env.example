# Copy to .env and fill in. .env is gitignored.

# FRED — required for HY/IG OAS targets and macro controls (VIX, UST yields).
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# Optional: override R discovery if rpy2 cannot find R automatically.
# R_HOME=/opt/homebrew/lib/R
